{
  "name": "schedex",
  "version": "1.0.0",
  "description": "CLI that discovers every scheduled job across infrastructure",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./scanners": {
      "types": "./dist/scanners/index.d.ts",
      "import": "./dist/scanners/index.js"
    },
    "./formatters": {
      "types": "./dist/formatters/index.d.ts",
      "import": "./dist/formatters/index.js"
    },
    "./cron": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "bin": {
    "schedex": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Darkroom4364/schedex"
  },
  "author": "Darkroom4364",
  "homepage": "https://github.com/Darkroom4364/schedex",
  "bugs": {
    "url": "https://github.com/Darkroom4364/schedex/issues"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src/",
    "format": "prettier --check src/",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "cron",
    "crontab",
    "scheduler",
    "infrastructure",
    "cli",
    "devops",
    "kubernetes",
    "systemd",
    "eventbridge",
    "scheduled-jobs",
    "monitoring"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@aws-sdk/client-eventbridge": "^3.1021.0",
    "commander": "^13.0.0",
    "yaml": "^2.8.3"
  }
}
